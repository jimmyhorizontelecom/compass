@{
    Layout = "~/Views/Shared/_TestLayout.cshtml";
}

<div class="container ">
    <div id="modalLoader1" class="modal-loader modalLoader">
        <div class="spinner"></div>
        <p class="loading-text">Please wait...</p>
    </div>
    <h4>Department Challan ESI EPF </h4>
    <div class="filter-panel mt-5 div-coral-base">

        <div class="form-group row">
            <div class="col-md-3 ">
                <label class="form-labelo">Month Year <span class="text-danger">*</span></label>
                <select id="ddlMonthYear" class="form-select form-select-sm search_ddl select2" aria-label=".form-select-sm">
                    <option selected value="0"> -- Select --</option>
                </select>
                <span class="error"></span>
            </div>
            <div class="col-md-3 mb-0">
                <label class="form-labelo">Agency Name<span class="text-danger">*</span></label>
                <select id="ddlAgencyName" class="form-select form-select-sm search_ddl select2" aria-label=".form-select-sm">
                    <option selected value="0"> -- Select --</option>
                </select>
                <span class="error"></span>
            </div>
            <div class="col-md-3 mb-0">
                <label class="form-labelo">Challan Type<span class="text-danger">*</span></label>
                <select id="ddlChallanType" class="form-select form-select-sm search_ddl select2" aria-label=".form-select-sm">
                    <option selected value="0"> -- Select --</option>
                </select>
                <span class="error"></span>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-3 mb-0">
                <label class="form-label">Challan No.<span class="text-danger">*</span></label>
                <input type="text" id="txtChallanNumber" class="form-control txtbx cleartxt" placeholder="Challan No." />
                <span class="error"></span>
            </div>
            <div class="col-md-3 mb-0">
                <label class="form-label">Challan Date<span class="text-danger">*</span></label>
                <input type="date" id="dateChallanDate" class="form-control txtbx cleartxt" />
                <span class="error"></span>
            </div>
            <div class="col-md-3 mb-0">
                <label class="form-label">No. of HPSEDC Resources<span class="text-danger">*</span></label>
                <input type="text" id="txtNoOfHPSEDECResources" class="form-control txtbx cleartxt" placeholder="No. of HPSEDC Resources" />
                <span class="error"></span>
            </div>
            <div class="col-md-3 mb-0">
                <label class="form-label">Challan Amount<span class="text-danger">*</span></label>
                <input type="text" id="txtChallanAmt" class="form-control txtbx cleartxt" placeholder="Challan Amount" />
                <span class="error"></span>
            </div>

        </div>
        <div class="form-group row">
            <div class="col-md-3 mb-0">
                <label class="form-label">Upload Challan Payment Confirmation Receipt<span class="text-danger">*</span></label>
                <div class="input-group mb-0">
                    <input type="file" class="form-control" id="inputGroupFile02">
                    @*  <label class="input-group-text" for="inputGroupFile02">Upload</label> *@
                </div>
                <span class="error">Only PDF File are allowed</span>
            </div>

            <div class="col-md-3 mb-0">
                <label class="form-label">Upload Employee Details (ECR)<span class="text-danger">*</span></label>
                <div class="input-group mb-0">
                    <input type="file" class="form-control" id="inputGroupFile02">
                    @*  <label class="input-group-text" for="inputGroupFile02">Upload</label> *@
                </div>
                <span class="error">Only PDF File are allowed</span>
            </div>

            <div class="col-md-6 mb-0">
               <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="flexCheckBoxDefault" id="">
                    <label class="form-check-label" for="flexCheckboxDefault1">
                        Declaration
                    </label>
                    <div>
                        I/We hereby declare that the submitted ESIC and EPF challan details and the corresponding 
                        uploaded documents are genuine, accurate, and in full compliance with all statutory requirements.
                        We accept full responsibility for the veracity of this information and understand that our agency is
                        liable for any inaccuracies or delays in statutory payments.
                        
                    </div>
               </div>

            </div>
            <div class="col-md-9 mb-0"> </div>
               <div class="col-md-3 mb-0">
                     <button type="button" class="btn  btn-coral txt-white" data-bs-toggle="modal" data-bs-target="#myModal">
                    Submit
                    </button>
                </div>
        </div>
    </div>

</div>


<div class="container mt-5">
    @* <h2 class="mb-4">User List</h2> *@
    <div class="filter-panel mt-5 div-coral-base">

        <table id="myTable" class="table orangeTh table-striped table-hover table-bordered">
            <thead class="bg-d">
                <tr>
                    <th>Sr.No</th>
                    <th>Month Year</th>
                    <th>Agency Name</th>
                    <th>Challan Type</th>
                    <th>Challan Number</th>
                    <th>Challan Date</th>
                    <th>No. of HPSEDC Resources</th>
                    <th>Total Challan Amount</th>
                    <th>View Payment Receipt & ECR</th>
                    <th>View Employee Details</th>
                    <th>Edit</th>
                   

                </tr>
            </thead>
            <tbody>
            </tbody>
            <tfoot class="tfoot bg-primary">
                <tr>
                    @* <td>3</td>
                    <td>Mike Brown</td>
                    <td>mike@example.com</td>
                    <td>Editor</td>
                    <td>Editor</td> *@
                </tr>
            </tfoot>
        </table>
    </div>
</div>
}


@section Scripts {
    <script src="~/PageAssets/Manpower/Js/depositchallanesiepf.js" asp-append-version="true"></script>
}
