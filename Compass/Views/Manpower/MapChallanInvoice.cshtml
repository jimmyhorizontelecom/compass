@{
    Layout = "~/Views/Shared/_TestLayout.cshtml";
}

<div class="container ">
    <div id="modalLoader1" class="modal-loader modalLoader">
        <div class="spinner"></div>
        <p class="loading-text">Please wait...</p>
    </div>
    <h4>Map Challan Invoice </h4>
    <div class="filter-panel mt-5 div-coral-base">

        <div class="form-group row">
            <div class="col-md-4">
                <label class="form-labelo">Month Year <span class="text-danger">*</span></label>
                <select id="ddlMonthYear" class="form-select form-select-sm search_ddl select2" aria-label=".form-select-sm">
                    <option selected value="0"> -- Select --</option>
                </select>
            </div>
            <div class="col-md-4 mb-0">
                <label class="form-labelo">Agency Name<span class="text-danger">*</span></label>
                <select id="ddlAgencyName" class="form-select form-select-sm search_ddl select2" aria-label=".form-select-sm">
                    <option selected value="0"> -- Select --</option>
                </select>
                <span class="error"></span>
            </div>
            <div class="col-md-4 mb-0">
                <label class="form-labelo">Challan Type<span class="text-danger">*</span></label>
                <select id="ddlChallanType" class="form-select form-select-sm search_ddl select2" aria-label=".form-select-sm">
                    <option selected value="0"> -- Select --</option>
                </select>
                <span class="error"></span>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-4 mb-0">
                <label class="form-labelo">Challan Number<span class="text-danger">*</span></label>
                <select id="ddlChallanNumber" class="form-select form-select-sm search_ddl select2" aria-label=".form-select-sm">
                    <option selected value="0"> -- Select --</option>
                </select>
                <span class="error"></span>
            </div>
            
            <div class="col-md-4 mb-0">
                <label class="form-label">Total Resources<span class="text-danger">*</span></label>
                <input type="text" id="txtTotalResources" class="form-control txtbx cleartxt" placeholder="Total Resources" readonly/>
                <span class="error"></span>
            </div>
            <div class="col-md-4 mb-0">
                <label class="form-label">Allocated Resource<span class="text-danger">*</span></label>
                <input type="text" id="txtChallanAmt" class="form-control txtbx cleartxt" placeholder="Allocated Resource" readonly />
                <span class="error"></span>
            </div>

        </div>
        
    </div>

</div>


<div class="container mt-5">
    @* <h2 class="mb-4">User List</h2> *@
    <div class="filter-panel mt-5 div-coral-base">
        <table id="myTable" class="table orangeTh table-striped table-hover table-bordered">         
            <thead class="bg-d">
                <tr>
                    <th>Sr.No</th>
                    <th><input type="checkbox" id="selectAll" /> Select All</th>
                    <th>Agency Bill No.</th>
                    <th>Agency Name</th>
                    <th>Bill for Month </th>
                    <th>Total Resources </th>
                    <th>Enter No. of Resources</th>
                  

                </tr>
            </thead>
            <tbody>
            </tbody>
            <tfoot class="tfoot bg-primary">
                <tr>
                    @* <td>3</td>
                    <td>Mike Brown</td>
                    <td>mike@example.com</td>
                    <td>Editor</td>
                    <td>Editor</td> *@
                </tr>
            </tfoot>
        </table>
    </div>
</div>
<div class="form-group row">
    <div class="col-md-9 mb-0"></div>
    <div class="col-md-3 mb-0">
        <button type="button" class="btn  btn-coral txt-white" data-bs-toggle="modal" data-bs-target="#myModal">
            Submit
        </button>

    </div>
</div>

}


@section Scripts {
    <script src="~/PageAssets/Manpower/Js/mapchallaninvoice.js" asp-append-version="true"></script>
}
